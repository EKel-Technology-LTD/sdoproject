<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_Industry_On_Create</fullName>
    <active>true</active>
    <errorConditionFormula
  >AND($Permission.SDO_Sales_Opportunity_Industry_Required, ISBLANK(TEXT(SDO_Sales_Industry__c)), OR(ISNEW(), ISCHANGED(SDO_Sales_Industry__c)))</errorConditionFormula>
    <errorDisplayField>SDO_Sales_Industry__c</errorDisplayField>
    <errorMessage>請填寫產業。</errorMessage>
</ValidationRule>
