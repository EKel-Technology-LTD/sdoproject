                <formulaExpression>NOT(ISBLANK({!Phone})) || NOT(ISBLANK({!Email}))</formulaExpression>
            </validationRule>
        </fields>
        <fields>
            <name>LeadSource</name>
            <choiceReferences>Partner_Choice</choiceReferences>
            <dataType>String</dataType>
            <defaultValue>
