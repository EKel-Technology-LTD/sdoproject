        <fields>
            <name>Intro_Text</name>
            <fieldText>&lt;p&gt;請輸入初次接觸 Lead 所需的最少資訊。公司若為 B2C 或未知，請在 Company 欄位填「未提供」。Phone 與 Email 至少需填一項。&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Name</name>
            <dataType>String</dataType>
            <fieldText>Name</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>true</isRequired>
        </fields>
        <fields>
            <name>Company</name>
            <dataType>String</dataType>
            <fieldText>Company</fieldText>
            <fieldType>InputField</fieldType>
            <helpText>B2B 請填真實公司名稱；B2C 或未知公司可填「未提供」。</helpText>
            <isRequired>true</isRequired>
        </fields>
