            <name>Phone</name>
            <dataType>String</dataType>
            <fieldText>Phone</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>false</isRequired>
            <validationRule>
                <errorMessage>Phone 或 Email 至少需填一項。</errorMessage>
                <formulaExpression>NOT(ISBLANK({!Phone})) || NOT(ISBLANK({!Email}))</formulaExpression>
            </validationRule>
        </fields>
        <fields>
            <name>Email</name>
            <dataType>String</dataType>
