<aura:component controller="SDO_LeadCreateAccessCtrl" implements="lightning:actionOverride,flexipage:availableForAllPageTypes" access="global">
    <aura:attribute name="checkedAccess" type="Boolean" default="false"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>

    <aura:if isTrue="{!v.checkedAccess}">
        <lightning:card title="New Lead">
            <lightning:flow aura:id="insideSalesLeadFlow" onstatuschange="{!c.handleStatusChange}"/>
        </lightning:card>
        <aura:set attribute="else">
            <lightning:spinner alternativeText="Loading" size="medium"/>
        </aura:set>
    </aura:if>
</aura:component>
