<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Sales Cloud retrieve manifest (Broad scope).
  Target org: sdo (EKel Technology, NA233).

  CustomObject members are listed explicitly so the retrieve stays scoped to the
  Sales Cloud data model rather than every object in the org. Each object's
  record types, list views, validation rules, compact layouts, web links,
  business processes and field customizations are decomposed INSIDE its
  .object-meta.xml folder — they are not separate <types> entries.

  Wildcards (*) on Layout / FlexiPage / PermissionSet / etc. exclude managed-package
  (namespaced) components by default, satisfying "don't include package contents".
-->
<Package xmlns="http://soap.sforce.com/2006/04/metadata">
    <!-- Core named objects -->
    <types>
        <members>Account</members>
        <members>Contact</members>
        <members>Lead</members>
        <members>Opportunity</members>
        <members>OpportunityLineItem</members>
        <members>OpportunityContactRole</members>
        <members>Case</members>
        <!-- Rest of the core Sales Cloud data model (Broad scope) -->
        <members>Campaign</members>
        <members>CampaignMember</members>
        <members>Product2</members>
        <members>Pricebook2</members>
        <members>Quote</members>
        <members>QuoteLineItem</members>
        <members>Contract</members>
        <members>Order</members>
        <members>OrderItem</members>
        <name>CustomObject</name>
    </types>

    <!-- Page layouts (classic record layouts) -->
    <types>
        <members>*</members>
        <name>Layout</name>
    </types>

    <!-- Lightning record pages (and app/home pages) -->
    <types>
        <members>*</members>
        <name>FlexiPage</name>
    </types>

    <!-- Compact layouts (highlights panel) -->
    <types>
        <members>*</members>
        <name>CompactLayout</name>
    </types>

    <!-- Permission sets -->
    <types>
        <members>*</members>
        <name>PermissionSet</name>
    </types>

    <!-- Sales apps and their tabs -->
    <types>
        <members>*</members>
        <name>CustomApplication</name>
    </types>
    <types>
        <members>*</members>
        <name>CustomTab</name>
    </types>

    <!-- Apex verification tests for Sales Cloud behavior -->
    <types>
        <members>SDO_Sales_OpenDaysTest</members>
        <name>ApexClass</name>
    </types>

    <!-- Sales automation -->
    <types>
        <members>*</members>
        <name>Flow</name>
    </types>
    <types>
        <members>*</members>
        <name>QuickAction</name>
    </types>

    <!-- Custom global picklist value sets -->
    <types>
        <members>*</members>
        <name>GlobalValueSet</name>
    </types>

    <!--
      StandardValueSet does NOT support the * wildcard — each value set must be
      named explicitly. These are the standard picklists behind the Sales Cloud
      objects above (stages, sources, statuses, types, etc.).
    -->
    <types>
        <members>AccountOwnership</members>
        <members>AccountRating</members>
        <members>AccountType</members>
        <members>Industry</members>
        <members>Salutation</members>
        <members>LeadSource</members>
        <members>LeadStatus</members>
        <members>OpportunityStage</members>
        <members>OpportunityType</members>
        <members>OpportunityCompetitor</members>
        <members>CampaignStatus</members>
        <members>CampaignType</members>
        <members>CampaignMemberStatus</members>
        <members>CaseStatus</members>
        <members>CaseOrigin</members>
        <members>CaseReason</members>
        <members>CasePriority</members>
        <members>CaseType</members>
        <members>ContractStatus</members>
        <members>OrderStatus</members>
        <members>OrderType</members>
        <members>QuoteStatus</members>
        <members>Product2Family</members>
        <members>QuantityUnitOfMeasure</members>
        <members>PartnerRole</members>
        <members>ContactRole</members>
        <members>AccountContactRole</members>
        <name>StandardValueSet</name>
    </types>

    <version>66.0</version>
</Package>
